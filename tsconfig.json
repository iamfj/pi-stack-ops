{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["node", "bun"]
  },
  "include": ["extensions/**/*.ts", "src/**/*.ts", "tests/**/*.ts", "tsup.config.ts"]
}
